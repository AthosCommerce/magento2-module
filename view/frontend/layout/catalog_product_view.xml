<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="athoscommerce.feed.tracking.global"
                   template="AthosCommerce_Feed::tracking/global-script.phtml">
                <arguments>
                    <argument name="global_script_model" xsi:type="object">AthosCommerce\Feed\ViewModel\GlobalScriptViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="athoscommerce.feed.tracking.product"
                   template="AthosCommerce_Feed::tracking/product-page.phtml">
                <arguments>
                    <argument name="global_script_model" xsi:type="object">AthosCommerce\Feed\ViewModel\GlobalScriptViewModel</argument>
                    <argument name="view_model" xsi:type="object">AthosCommerce\Feed\ViewModel\PdpViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
