<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="athoscommerce.tracking.product.page.data"
                   template="AthosCommerce_Feed::tracking/product-page.phtml">
                <arguments>
                    <argument name="global_script_view_model" xsi:type="object">AthosCommerce\Feed\ViewModel\GlobalScriptViewModel</argument>
                    <argument name="product_page_view_model" xsi:type="object">AthosCommerce\Feed\ViewModel\PdpViewModel</argument>
                    <argument name="escaper_view_model" xsi:type="object">AthosCommerce\Feed\ViewModel\Escaper</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
