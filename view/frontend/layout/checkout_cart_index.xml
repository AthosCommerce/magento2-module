<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="athoscommerce.tracking.cart.page.global"
                   template="AthosCommerce_Feed::tracking/global-script.phtml">
                <arguments>
                    <argument name="global_script_view_model" xsi:type="object">AthosCommerce\Feed\ViewModel\GlobalScriptViewModel</argument>
                    <argument name="escaper_view_model" xsi:type="object">AthosCommerce\Feed\ViewModel\Escaper</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Template"
                   name="athoscommerce.tracking.cart.page.shopperId"
                   template="AthosCommerce_Feed::tracking/shopper-id.phtml">
                <arguments>
                    <argument name="global_script_view_model" xsi:type="object">AthosCommerce\Feed\ViewModel\GlobalScriptViewModel</argument>
                    <argument name="escaper_view_model" xsi:type="object">AthosCommerce\Feed\ViewModel\Escaper</argument>
                    <argument name="shopper_id_timeout" xsi:type="number">3600000</argument><!-- 1 hour in milliseconds -->
                </arguments>
            </block>
        </referenceContainer>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="athoscommerce.tracking.cart.page.data"
                   template="AthosCommerce_Feed::tracking/cart-tracking.phtml">
                <arguments>
                    <argument name="global_script_view_model" xsi:type="object">AthosCommerce\Feed\ViewModel\GlobalScriptViewModel</argument>
                    <argument name="cart_view_model" xsi:type="object">AthosCommerce\Feed\ViewModel\CartViewModel</argument>
                    <argument name="escaper_view_model" xsi:type="object">AthosCommerce\Feed\ViewModel\Escaper</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
