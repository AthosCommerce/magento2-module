<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="searchspring_script" type="host">*.searchspring.net</value>
                <value id="athoscommerce_script" type="host">*.athoscommerce.net</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="searchspring_connect_net" type="host">*.searchspring.net</value>
                <value id="athoscommerce_connect_net" type="host">*.athoscommerce.net</value>
            </values>
        </policy>
        <policy id="style-src">
            <values>
                <value id="searchspring_style" type="host">*.searchspring.net</value>
                <value id="athoscommerce_style" type="host">*.athoscommerce.net</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
